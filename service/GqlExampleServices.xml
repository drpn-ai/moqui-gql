<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://moqui.org/xsd/service-definition-3.xsd">
    <!--
      Example service-backed resolvers for the GraphQL layer (decision 12). These demonstrate fields
      whose value is produced by a Moqui service rather than read from a column. The schema artifact's
      resolver-service points here; the engine batches calls through a DataLoader.
    -->
    <!-- get#OrderCustomerName was RETIRED: customer name is a join + concat, not genuine computation,
         so it is now the view-backed Order.billToCustomer leaf object (leaf-over-service, design.md
         decision 12). get#OrderItemCount was likewise RETIRED (#37): the order line count is now the
         lazy LATERAL aggregate Order.orderItemCount (COUNT(DISTINCT externalId)) — an aggregate-field
         kind, not a per-row service call. The service-backed-field CAPABILITY (ServiceBackedLoader, the
         resolver-service field kind, the governor's service-field branch) is retained and covered by
         ServiceBackedLoaderTests; it currently has no production schema user. -->

    <!-- get#InventoryLevels was RETIRED (#35): inventoryLevels is now a view-backed Relay connection over
         ProductFacilityInventoryItemView (ProductFacility LEFT-joined to the current InventoryItem), not a
         service-backed root. It was the last service-backed ROOT; the inventory-key governor cap
         (maxInventoryKeys/checkInventoryKeyCap) went with it. -->

    <!-- Test-only single-in/single-out echo: keeps the service-backed-field CAPABILITY regression-covered
         (ServiceBackedLoaderTests) after the only production service-backed field (itemCount) was retired
         (#37). authenticate="false" so the loader unit test can call it without a logged-in user (core
         BasicServices.echo#Data requires login). Not referenced by any schema field. -->
    <service verb="echo" noun="GqlField" authenticate="false">
        <in-parameters><parameter name="value"/></in-parameters>
        <out-parameters><parameter name="value"/></out-parameters>
        <actions><!-- value passes straight through (in == out) --></actions>
    </service>

    <!-- Idempotent test-data generator: ensure N sales Shipments exist (linked to real orders) so the
         shipments root has data. Marked externalId GQLTEST-<orderId>; re-running never duplicates. -->
    <service verb="ensure" noun="TestShipments" authenticate="false">
        <in-parameters><parameter name="count" type="Integer" default-value="5"/></in-parameters>
        <out-parameters><parameter name="shipmentIds" type="List"/></out-parameters>
        <actions>
            <script><![CDATA[
                shipmentIds = []
                def orders = ec.entity.find("org.apache.ofbiz.order.order.OrderHeader")
                        .selectField("orderId").orderBy("orderId").maxRows(count).fetchSize(count).list()
                for (oh in orders) {
                    def ext = "GQLTEST-" + oh.orderId
                    def existing = ec.entity.find("org.apache.ofbiz.shipment.shipment.Shipment")
                            .condition("externalId", ext).selectField("shipmentId").maxRows(1).fetchSize(1).list()
                    if (existing) { shipmentIds.add(existing[0].shipmentId); continue }
                    def s = ec.entity.makeValue("org.apache.ofbiz.shipment.shipment.Shipment")
                    s.setAll([shipmentTypeId: "SALES_SHIPMENT", statusId: "SHIPMENT_SHIPPED",
                              primaryOrderId: oh.orderId, originFacilityId: "M100002",
                              estimatedShipDate: ec.user.nowTimestamp, externalId: ext])
                    s.setSequencedIdPrimary(); s.create()
                    shipmentIds.add(s.shipmentId)
                }
            ]]></script>
        </actions>
    </service>
</services>
