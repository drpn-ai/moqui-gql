<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://moqui.org/xsd/entity-definition-3.xsd">
    <!-- Observability raw rows — query-log v2 policy: every REJECTED request, ALLOWED requests that
         are slow for their shape (QueryStats: avg + 2.6 sigma after warm-up, over slowMinMillis), and
         a small random sample (gql.queryLog.sampleRate). Aggregates for every hit are in
         GqlQueryStatsBin; rows join shapes via queryHash. Written in its own transaction so a log
         failure never fails the user's request. Purged after gql.queryLog.retainDays. -->
    <entity entity-name="GqlQueryLog" package="moqui.gql" short-alias="gqlQueryLogs">
        <description>One raw observability row per logged GraphQL request: verdict, governor cost,
            rows fetched, duration, and the query text. See the v2 logging policy above for which
            requests produce a row.</description>
        <field name="queryLogId" type="id" is-pk="true"/>
        <field name="queryDate" type="date-time"/>
        <field name="userId" type="id"/>
        <field name="callerProfile" type="text-short"/>
        <field name="verdict" type="text-short"/>
        <field name="rejectReason" type="text-medium"/>
        <field name="estimatedCost" type="number-integer"/>
        <field name="rowsFetched" type="number-integer"/>
        <field name="durationMs" type="number-integer"/>
        <field name="queryHash" type="text-medium"/>
        <field name="slowHit" type="text-indicator"/>
        <field name="queryText" type="text-very-long"/>
        <index name="GQL_QLOG_DATE"><index-field name="queryDate"/></index>
        <index name="GQL_QLOG_HASH"><index-field name="queryHash"/></index>
    </entity>

    <!-- One row per distinct query SHAPE (hash of the raw query string — the same identity the
         preparsed-document cache keys on). Raw log rows and stats bins join here by queryHash so
         analysis groups by shape without parsing truncated query text. -->
    <entity entity-name="GqlQueryShape" package="moqui.gql" short-alias="gqlQueryShapes">
        <description>A distinct GraphQL query shape: queryHash = SHA-256 hex of the raw query string,
            with the (truncated) query text captured once on first sight.</description>
        <field name="queryHash" type="text-medium" is-pk="true"/>
        <field name="queryText" type="text-very-long"/>
        <field name="firstSeenDate" type="date-time"/>
    </entity>

    <!-- Per-shape execution aggregates (the framework ArtifactHitBin analogue), flushed inline when a
         bin ages past gql.queryLog.binSeconds. avg(totalDurationMs/hitCount) vs avg(totalCost/hitCount)
         per shape IS the cost-model calibration dataset; totalSquaredDuration enables stddev. -->
    <entity entity-name="GqlQueryStatsBin" package="moqui.gql" short-alias="gqlQueryStatsBins">
        <description>One time-bin of execution stats for a query shape: hit/slow counts, duration
            totals and extrema, summed governor cost and rows fetched.</description>
        <field name="statsBinId" type="id" is-pk="true"/>
        <field name="queryHash" type="text-medium"/>
        <field name="binStartDate" type="date-time"/>
        <field name="binEndDate" type="date-time"/>
        <field name="hitCount" type="number-integer"/>
        <field name="slowHitCount" type="number-integer"/>
        <field name="totalDurationMs" type="number-integer"/>
        <field name="totalSquaredDuration" type="number-float"/>
        <field name="minDurationMs" type="number-integer"/>
        <field name="maxDurationMs" type="number-integer"/>
        <field name="totalCost" type="number-integer"/>
        <field name="totalRows" type="number-integer"/>
        <relationship type="one" related="moqui.gql.GqlQueryShape" short-alias="shape">
            <key-map field-name="queryHash"/></relationship>
        <index name="GQL_QSBIN_SHAPE"><index-field name="queryHash"/><index-field name="binStartDate"/></index>
    </entity>

    <!-- Phase-2 caller policy. A profile sets per-caller governor limits (null field = inherit the
         global config default) and an optional row-scope (productStore). Absence of any profile row =
         the global defaults (the engine treats a missing profile as "default"). -->
    <entity entity-name="GqlCallerProfile" package="moqui.gql">
        <field name="profileId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="maxCost" type="number-integer"/>
        <field name="maxFirst" type="number-integer"/>
        <field name="maxInventoryKeys" type="number-integer"/>
        <field name="bucketSize" type="number-integer"/>
        <field name="restoreRate" type="number-integer"/>
        <field name="scopeProductStoreId" type="id"/>
    </entity>

    <!-- Maps a caller (userId) to a profile. No row -> the "default" profile (global config). -->
    <entity entity-name="GqlCallerProfileMember" package="moqui.gql">
        <field name="userId" type="id" is-pk="true"/>
        <field name="profileId" type="id"/>
        <relationship type="one" related="moqui.gql.GqlCallerProfile"><key-map field-name="profileId"/></relationship>
    </entity>

    <!-- Per-client API key for the PUBLIC GraphQL tier (separate auth realm from the internal /graphql
         session endpoint). SECURITY-CRITICAL: the raw key is NEVER stored — only its SHA-256 hex digest
         (keyHash). Resolution looks the key up BY HASH (no raw compare, no substring/like match), which
         also avoids timing leaks on the raw key. Each key is bound to exactly one tenant
         (companyUserGroupId) and an optional cost profile; the public endpoint scopes every read to that
         fixed tenant (DarpanTenantScopeFilter(companyUserGroupId)), never the session/TenantAccessSupport
         path. use="configuration" so it lives with the runtime config DB like the other gql control
         entities. -->
    <entity entity-name="GqlApiKey" package="moqui.gql" use="configuration">
        <description>A per-client API key for the public GraphQL tier. keyHash = SHA-256 hex of the full
            raw key (the raw key is shown once at mint time and is NOT recoverable). Bound to one tenant
            (companyUserGroupId) and an optional GqlCallerProfile.</description>
        <field name="apiKeyId" type="id" is-pk="true"/>
        <field name="keyHash" type="text-medium"><description>SHA-256 hex digest of the full raw key. The raw key is never stored.</description></field>
        <field name="companyUserGroupId" type="id"><description>The single tenant this key is scoped to (required). Every public read is fixed to this tenant.</description></field>
        <field name="profileId" type="id"><description>Optional cost/governor profile (GqlCallerProfile). Null = global defaults.</description></field>
        <field name="clientName" type="text-medium"><description>Human-readable client identity for audit/identification.</description></field>
        <field name="enabled" type="text-indicator"><default>Y</default></field>
        <field name="expireDate" type="date-time"><description>Optional expiry; once passed the key resolves invalid (fail-closed).</description></field>
        <field name="lastUsedDate" type="date-time"><description>Best-effort last successful resolution timestamp.</description></field>
        <field name="createdDate" type="date-time"/>
        <relationship type="one" related="moqui.gql.GqlCallerProfile"><key-map field-name="profileId"/></relationship>
        <index name="GQL_APIKEY_HASH" unique="true"><index-field name="keyHash"/></index>
    </entity>

    <!-- The BILL_TO customer of an order, as leaf columns (orderId 1:1 -> Person name). Backs the
         Order.billToCustomer has-one edge so clients read firstName/lastName and compose the display
         name themselves — replacing the get#OrderCustomerName service-backed field (leaf-over-service). -->
    <view-entity entity-name="OrderBillToCustomer" package="moqui.gql">
        <member-entity entity-alias="ORD" entity-name="org.apache.ofbiz.order.order.OrderHeader"/>
        <member-entity entity-alias="ROL" entity-name="org.apache.ofbiz.order.order.OrderRole" join-from-alias="ORD">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="PER" entity-name="org.apache.ofbiz.party.party.Person" join-from-alias="ROL">
            <key-map field-name="partyId"/>
        </member-entity>
        <alias name="orderId" entity-alias="ORD"/>
        <alias name="partyId" entity-alias="ROL"/>
        <alias name="firstName" entity-alias="PER"/>
        <alias name="lastName" entity-alias="PER"/>
        <entity-condition>
            <econdition entity-alias="ROL" field-name="roleTypeId" value="BILL_TO_CUSTOMER"/>
        </entity-condition>
    </view-entity>

    <!-- #43: a ship group's origin (facility) postal address, as leaf columns incl. lat/long. Backs the
         ShipGroup.shipFromAddress has-one edge (keyed by facilityId). Distinct from ofbiz-oms-udm's
         FacilityContactDetailByPurpose: that view excludes latitude/longitude and applies no purpose
         filter; this one pins the SHIP_ORIG_LOCATION purpose and surfaces GeoPoint.latitude/longitude.
         join-optional on the address chain so a facility with no postal address still yields a row keyed
         by facilityId (the edge then resolves to null fields, never an error). Both FCM and FCMP carry
         effective-date PK fields (fromDate/thruDate), so the entity-condition date-filters BOTH aliases:
         FCMP (the purpose) and FCM (the facility<->contactMech assignment). Without the FCM filter, every
         effective generation of a (facilityId, contactMechId) assignment fans out and the view can return
         >1 row per facility — the has-one would then pick one arbitrarily. With both filtered the view is
         deterministically <= 1 row per facilityId, PROVIDED a facility has a single effective
         SHIP_ORIG_LOCATION origin contact mech. If a facility has multiple effective origin addresses, the
         has-one returns an arbitrary one — the same property the moqui.gql.OrderBillToCustomer /
         billToCustomer has-one carries. -->
    <view-entity entity-name="FacilityOriginAddress" package="moqui.gql">
        <member-entity entity-alias="FA" entity-name="org.apache.ofbiz.product.facility.Facility"/>
        <member-entity entity-alias="FCM" entity-name="org.apache.ofbiz.product.facility.FacilityContactMech" join-from-alias="FA">
            <key-map field-name="facilityId"/>
        </member-entity>
        <member-entity entity-alias="FCMP" entity-name="org.apache.ofbiz.product.facility.FacilityContactMechPurpose" join-from-alias="FCM">
            <key-map field-name="facilityId"/>
            <key-map field-name="contactMechId"/>
        </member-entity>
        <member-entity entity-alias="PA" entity-name="org.apache.ofbiz.party.contact.PostalAddress" join-from-alias="FCM" join-optional="true">
            <key-map field-name="contactMechId"/>
        </member-entity>
        <member-entity entity-alias="GP" entity-name="moqui.basic.GeoPoint" join-from-alias="PA" join-optional="true">
            <key-map field-name="geoPointId"/>
        </member-entity>
        <alias name="facilityId" entity-alias="FA"/>
        <alias name="contactMechId" entity-alias="FCM"/>
        <alias name="contactMechPurposeTypeId" entity-alias="FCMP"/>
        <alias name="toName" entity-alias="PA"/>
        <alias name="attnName" entity-alias="PA"/>
        <alias name="address1" entity-alias="PA"/>
        <alias name="address2" entity-alias="PA"/>
        <alias name="city" entity-alias="PA"/>
        <alias name="postalCode" entity-alias="PA"/>
        <alias name="stateProvinceGeoId" entity-alias="PA"/>
        <alias name="countryGeoId" entity-alias="PA"/>
        <alias name="latitude" entity-alias="GP"/>
        <alias name="longitude" entity-alias="GP"/>
        <entity-condition>
            <econdition entity-alias="FCMP" field-name="contactMechPurposeTypeId" value="SHIP_ORIG_LOCATION"/>
            <date-filter entity-alias="FCMP"/>
            <date-filter entity-alias="FCM"/>
        </entity-condition>
    </view-entity>

    <!-- Per-window anomaly alert for a caller (API key / userId). One row is emitted per (caller,
         metric, window) when a threshold is breached by scan#QueryAnomalies. The (userId, metricType,
         windowStartDate) index is used by the dedup check: skip if a row already exists for the same
         caller+metric with windowStartDate >= the current window start, so at most one alert fires per
         caller per metric per window. status starts 'NEW'; an operator can set it to 'ACK' or 'RESOLVED'
         to track action taken. -->
    <entity entity-name="GqlAnomalyAlert" package="moqui.gql" use="transactional">
        <description>One sustained-abuse alert per (caller, metric, window). Emitted by
            scan#QueryAnomalies when a per-window threshold is breached. Deduped by
            (userId, metricType, windowStartDate) so at most one alert fires per combination.</description>
        <field name="alertId" type="id" is-pk="true"/>
        <field name="userId" type="id"><description>The API key ID (apiKeyId) or session userId of the caller.</description></field>
        <field name="metricType" type="text-short"><description>One of VOLUME, REJECT_RATE, COST.</description></field>
        <field name="windowStartDate" type="date-time"/>
        <field name="windowEndDate" type="date-time"/>
        <field name="observedValue" type="number-decimal"/>
        <field name="threshold" type="number-decimal"/>
        <field name="queryCount" type="number-integer"/>
        <field name="rejectCount" type="number-integer"/>
        <field name="totalCost" type="number-integer"/>
        <field name="status" type="text-short" default="NEW"/>
        <field name="alertDate" type="date-time"/>
        <index name="GQL_AALERT_CALLER"><index-field name="userId"/><index-field name="metricType"/><index-field name="windowStartDate"/></index>
    </entity>

    <!-- #43: inverse of OrderFacilityChange's one-relationship to OrderItemShipGroup (fk ORDER_OFC_OISG).
         Backs the ShipGroup.facilityChangeHistory has-many edge, keyed by (orderId, shipGroupSeqId).
         Declared here (gql-owned) rather than in runtime/component/oms per the no-touch-components rule;
         mirrors the existing OrderItemShipGroup.items relationship. The nested loader orders children by
         the child PK (orderFacilityChangeId), which is assigned in change-time order, so the audit trail
         reads oldest -> newest. -->
    <extend-entity entity-name="OrderItemShipGroup" package="org.apache.ofbiz.order.order">
        <relationship type="many" related="co.hotwax.facility.OrderFacilityChange" short-alias="facilityChanges">
            <key-map field-name="orderId"/>
            <key-map field-name="shipGroupSeqId"/>
        </relationship>
    </extend-entity>
</entities>
