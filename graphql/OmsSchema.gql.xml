<?xml version="1.0" encoding="UTF-8"?>
<!--
  GraphQL schema artifact (initial scope). Field/type names = OMS data model; query language is
  Shopify-shaped (query: search string, sortKey+reverse, Relay connections). Entity names are the
  HotWax/OFBiz model present in hcsd_notnaked. Grows toward docs/schema.graphql.
-->
<gql-schema>
    <gql-type name="Order" entity-name="org.apache.ofbiz.order.order.OrderHeader">
        <field name="orderId" entity-field="orderId" type="ID"/>
        <field name="orderName" entity-field="orderName"/>
        <field name="externalId" entity-field="externalId"/>
        <field name="statusId" entity-field="statusId"/>
        <field name="orderDate" entity-field="orderDate" type="DateTime"/>
        <field name="grandTotal" entity-field="grandTotal" type="Decimal"/>
        <field name="currencyUomId" entity-field="currencyUom"/>
        <field name="productStoreId" entity-field="productStoreId"/>
        <!-- aggregate field (lazy LATERAL): number of distinct Shopify order lines. Exploded OMS items
             from one Shopify line share OrderItem.externalId, so COUNT(DISTINCT externalId) = line count.
             Resolved by a sub-select member added to the dynamic view only when this field is selected. -->
        <field name="orderItemCount" type="Int"
               aggregate="count-distinct" aggregate-entity="org.apache.ofbiz.order.order.OrderItem"
               aggregate-fk="orderId" aggregate-field="externalId"/>
        <!-- has-one leaf object (was the service-backed customerName): the BILL_TO customer's leaf
             columns via a 1:1 view; the client composes the display name. Deterministic cost, no
             service call (leaf-over-service rule, design.md decision 12). -->
        <edge name="billToCustomer" target-type="BillToCustomer" entity-name="moqui.gql.OrderBillToCustomer"
              fk="orderId" single="true"/>
        <edge name="orderItems" entity-relationship="OrderItem" target-type="OrderItem" list="true"/>
        <!-- plain bounded list (not a connection): typed external ids for this order -->
        <edge name="identifications" entity-relationship="OrderIdentification" target-type="OrderIdentification"
              list="true" kind="list" first-default="10"/>
        <!-- ship groups: a Relay connection (composite child PK orderId+shipGroupSeqId, single-key join).
             #38: exclude-empty="items" drops ship groups with zero OrderItem rows (one batched DISTINCT query). -->
        <edge name="shipGroups" entity-relationship="shipGroups" target-type="ShipGroup" list="true" exclude-empty="items"/>
        <!-- small fixed metadata: plain bounded lists -->
        <edge name="statuses" entity-relationship="statuses" target-type="OrderStatus" list="true" kind="list" first-default="50"/>
        <edge name="adjustments" entity-relationship="adjustments" target-type="OrderAdjustment" list="true" kind="list" first-default="50"/>
        <edge name="paymentPreferences" entity-relationship="paymentPreferences" target-type="OrderPaymentPreference" list="true" kind="list" first-default="20"/>
        <root-query name="order" by-pk="true" pk-arg="orderId" external-id="true"/>
        <root-query name="orders" list="true"
            search-keys="orderId:eq,in externalId:eq,in orderName:eq statusId:eq,in orderDate:gt,gte,lt,lte productStoreId:eq,in"
            sort-keys="ORDER_DATE:orderDate ORDER_NAME:orderName GRAND_TOTAL:grandTotal ORDER_ID:orderId"/>
        <!-- indirect external-id lookup: OrderIdentification(typeId, idValue) -> Order -->
        <root-query name="orderByIdentification" by-identification="true"
            identification-entity="co.hotwax.order.OrderIdentification"
            type-arg="identificationTypeId" type-field="orderIdentificationTypeId"
            value-arg="idValue" value-field="idValue" fk-field="orderId"/>
    </gql-type>

    <gql-type name="OrderIdentification" entity-name="co.hotwax.order.OrderIdentification">
        <field name="orderIdentificationTypeId" entity-field="orderIdentificationTypeId" type="ID"/>
        <field name="idValue" entity-field="idValue"/>
    </gql-type>

    <!-- Leaf columns of an order's BILL_TO customer (view-backed). The client composes a display name
         from firstName + lastName — we expose the data, not the presentation. -->
    <gql-type name="BillToCustomer" entity-name="moqui.gql.OrderBillToCustomer">
        <field name="partyId" type="ID"/>
        <field name="firstName"/>
        <field name="lastName"/>
    </gql-type>

    <!-- #43: leaf columns of a ship group's origin (facility) address incl. lat/long, view-backed
         (moqui.gql.FacilityOriginAddress, purpose SHIP_ORIG_LOCATION). -->
    <gql-type name="FacilityOriginAddress" entity-name="moqui.gql.FacilityOriginAddress">
        <field name="facilityId" type="ID"/>
        <field name="address1"/>
        <field name="address2"/>
        <field name="city"/>
        <field name="postalCode"/>
        <field name="stateProvinceGeoId"/>
        <field name="countryGeoId"/>
        <field name="latitude" type="Decimal"/>
        <field name="longitude" type="Decimal"/>
    </gql-type>

    <!-- #43: the resolved descriptive shipping method for a ship group (id + label). -->
    <gql-type name="ShipmentMethodType" entity-name="org.apache.ofbiz.shipment.shipment.ShipmentMethodType">
        <field name="shipmentMethodTypeId" type="ID"/>
        <field name="description"/>
    </gql-type>

    <!-- #43: a single facility-change record for a ship group (audit trail row). -->
    <gql-type name="OrderFacilityChange" entity-name="co.hotwax.facility.OrderFacilityChange">
        <field name="orderFacilityChangeId" type="ID"/>
        <field name="shipGroupSeqId"/>
        <field name="fromFacilityId"/>
        <field name="facilityId"/>
        <field name="changeDatetime" type="DateTime"/>
        <field name="changeReasonEnumId"/>
        <field name="comments"/>
    </gql-type>

    <gql-type name="OrderStatus" entity-name="org.apache.ofbiz.order.order.OrderStatus">
        <field name="statusId" type="ID"/>
        <field name="statusDatetime" type="DateTime"/>
        <field name="orderItemSeqId"/>
    </gql-type>

    <gql-type name="OrderAdjustment" entity-name="org.apache.ofbiz.order.order.OrderAdjustment">
        <field name="orderAdjustmentId" type="ID"/>
        <field name="orderAdjustmentTypeId"/>
        <field name="amount" type="Decimal"/>
        <field name="comments"/>
    </gql-type>

    <gql-type name="OrderPaymentPreference" entity-name="org.apache.ofbiz.order.order.OrderPaymentPreference">
        <field name="orderPaymentPreferenceId" type="ID"/>
        <field name="paymentMethodTypeId"/>
        <field name="maxAmount" type="Decimal"/>
        <field name="statusId"/>
    </gql-type>

    <gql-type name="ShipGroup" entity-name="org.apache.ofbiz.order.order.OrderItemShipGroup">
        <field name="shipGroupSeqId" type="ID"/>
        <field name="shipmentMethodTypeId"/>
        <field name="carrierPartyId"/>
        <field name="facilityId"/>
        <field name="contactMechId"/>
        <!-- composite-key nested edge (#38): items of this ship group via the OrderItemShipGroup.items
             relationship (orderId + shipGroupSeqId), navigating OrderItem.shipGroupSeqId (NOT OrderItemShipGroupAssoc). -->
        <edge name="orderItems" entity-relationship="items" target-type="OrderItem" list="true"/>
        <!-- #43: ship group origin (facility) postal address incl. lat/long. Single-key has-one
             (the billToCustomer pattern): batched WHERE facilityId IN(:keys), no N+1. Works today. -->
        <edge name="shipFromAddress" target-type="FacilityOriginAddress" entity-name="moqui.gql.FacilityOriginAddress"
              fk="facilityId" single="true"/>
        <!-- #43: the ship group's shipping method (ShipmentMethodType id + description).
             Single-key has-one on shipmentMethodTypeId — the billToCustomer pattern, works today.
             Carrier identity stays on the carrierPartyId scalar (the composite carrier edge was dropped). -->
        <edge name="shippingMethod" target-type="ShipmentMethodType"
              entity-name="org.apache.ofbiz.shipment.shipment.ShipmentMethodType"
              fk="shipmentMethodTypeId" single="true"/>
        <!-- #43: facility-change audit trail for this ship group. Composite-key has-many (orderId,
             shipGroupSeqId) via the OrderItemShipGroup.facilityChanges relationship -> rides #38's
             composite NestedConnectionLoader. Ordered by the child PK (orderFacilityChangeId), which is
             assigned in change-time order. -->
        <edge name="facilityChangeHistory" entity-relationship="facilityChanges"
              target-type="OrderFacilityChange" list="true"/>
    </gql-type>

    <gql-type name="OrderItem" entity-name="org.apache.ofbiz.order.order.OrderItem">
        <field name="orderId" entity-field="orderId" type="ID"/>
        <field name="orderItemSeqId" entity-field="orderItemSeqId" type="ID"/>
        <field name="productId" entity-field="productId"/>
        <field name="quantity" entity-field="quantity" type="Int"/>
        <field name="unitPrice" entity-field="unitPrice" type="Decimal"/>
        <field name="statusId" entity-field="statusId"/>
    </gql-type>

    <!-- View-entity-backed type (decision 12): firstName/lastName/roleTypeId come from a Party+Person+
         PartyRole join. Composite PK (partyId, roleTypeId) exercises the composite-PK keyset cursor. -->
    <gql-type name="Party" entity-name="co.hotwax.party.party.PartyNameAndRoleDetail">
        <field name="partyId" entity-field="partyId" type="ID"/>
        <field name="partyTypeId" entity-field="partyTypeId"/>
        <field name="roleTypeId" entity-field="roleTypeId"/>
        <field name="firstName" entity-field="firstName"/>
        <field name="lastName" entity-field="lastName"/>
        <field name="externalId" entity-field="externalId"/>
        <field name="statusId" entity-field="statusId"/>
        <root-query name="party" by-pk="true" pk-arg="partyId" external-id="true"/>
        <root-query name="parties" list="true"
            search-keys="partyId:eq,in externalId:eq,in firstName:eq lastName:eq roleTypeId:eq,in"
            sort-keys="PARTY_ID:partyId LAST_NAME:lastName"/>
    </gql-type>

    <!-- Entity-backed type + new roots (single PK). estimatedShipDate is the Shipment date field
         (our data-model name) mapped to the SHIPPED_DATE sort key. -->
    <gql-type name="Shipment" entity-name="org.apache.ofbiz.shipment.shipment.Shipment">
        <field name="shipmentId" entity-field="shipmentId" type="ID"/>
        <field name="shipmentTypeId" entity-field="shipmentTypeId"/>
        <field name="statusId" entity-field="statusId"/>
        <field name="primaryOrderId" entity-field="primaryOrderId"/>
        <field name="originFacilityId" entity-field="originFacilityId"/>
        <field name="destinationFacilityId" entity-field="destinationFacilityId"/>
        <field name="shipmentMethodTypeId" entity-field="shipmentMethodTypeId"/>
        <field name="estimatedShipDate" entity-field="estimatedShipDate" type="DateTime"/>
        <field name="externalId" entity-field="externalId"/>
        <root-query name="shipment" by-pk="true" pk-arg="shipmentId" external-id="true"/>
        <root-query name="shipments" list="true"
            search-keys="shipmentId:eq,in statusId:eq,in originFacilityId:eq,in shipmentMethodTypeId:eq,in estimatedShipDate:gt,gte,lt,lte"
            sort-keys="SHIPPED_DATE:estimatedShipDate STATUS:statusId SHIPMENT_ID:shipmentId"/>
    </gql-type>

    <gql-type name="Return" entity-name="org.apache.ofbiz.order.return.ReturnHeader">
        <field name="returnId" entity-field="returnId" type="ID"/>
        <field name="statusId" entity-field="statusId"/>
        <field name="returnHeaderTypeId" entity-field="returnHeaderTypeId"/>
        <field name="fromPartyId" entity-field="fromPartyId"/>
        <field name="entryDate" entity-field="entryDate" type="DateTime"/>
        <field name="externalId" entity-field="externalId"/>
        <field name="currencyUomId" entity-field="currencyUomId"/>
        <root-query name="return" by-pk="true" pk-arg="returnId" external-id="true"/>
        <root-query name="returns" list="true"
            search-keys="returnId:eq,in statusId:eq,in fromPartyId:eq,in entryDate:gt,gte,lt,lte"
            sort-keys="RETURN_DATE:entryDate STATUS:statusId RETURN_ID:returnId"/>
    </gql-type>

    <!-- View-entity-backed ROOT (decision 12): the canonical oms view ProductFacilityInventoryItemView
         (ProductFacility LEFT-joined to the current InventoryItem via ProductFacility.inventoryItemId).
         Driven by ProductFacility — one row per configured product+facility; ATP/QOH are COALESCEd to 0
         (never null) when unstocked/depleted. The view's composite PK (productId, facilityId) is the
         keyset cursor (same machinery as the parties root). productId/facilityId are both ProductFacility
         PK columns → index-backed search keys; the decimals are intentionally not in search/sort keys. -->
    <gql-type name="InventoryLevel" entity-name="co.hotwax.oms.product.inventory.ProductFacilityInventoryItemView">
        <field name="productId" entity-field="productId" type="ID"/>
        <field name="facilityId" entity-field="facilityId" type="ID"/>
        <field name="availableToPromise" entity-field="availableToPromise" type="Decimal"/>
        <field name="quantityOnHand" entity-field="quantityOnHand" type="Decimal"/>
        <root-query name="inventoryLevels" list="true"
            search-keys="productId:eq,in facilityId:eq,in"
            sort-keys="PRODUCT_ID:productId FACILITY_ID:facilityId"/>
    </gql-type>

    <gql-type name="Product" entity-name="org.apache.ofbiz.product.product.Product">
        <field name="productId" type="ID"/>
        <field name="productName"/>
        <field name="productTypeId"/>
        <field name="primaryProductCategoryId"/>
        <field name="brandName"/>
        <root-query name="product" by-pk="true" pk-arg="productId"/>
        <root-query name="products" list="true"
            search-keys="productId:eq,in productTypeId:eq,in primaryProductCategoryId:eq,in brandName:eq"
            sort-keys="PRODUCT_NAME:productName PRODUCT_ID:productId"/>
    </gql-type>

    <gql-type name="Facility" entity-name="org.apache.ofbiz.product.facility.Facility">
        <field name="facilityId" type="ID"/>
        <field name="facilityName"/>
        <field name="facilityTypeId"/>
        <field name="parentFacilityId"/>
        <field name="externalId"/>
        <root-query name="facility" by-pk="true" pk-arg="facilityId" external-id="true"/>
        <root-query name="facilities" list="true"
            search-keys="facilityId:eq,in facilityTypeId:eq,in externalId:eq,in parentFacilityId:eq,in"
            sort-keys="FACILITY_NAME:facilityName FACILITY_ID:facilityId"/>
    </gql-type>
</gql-schema>
